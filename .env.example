# PostgreSQL connection string used by SQLAlchemy.
# Format:
#   postgresql+psycopg://<username>:<password>@<host>:<port>/<database_name>
# Example (local dev):
#   postgresql+psycopg://postgres:admin@localhost:5432/rag_saas
DATABASE_URL

# random string
ADMIN_BOOTSTRAP_TOKEN

# get pinecone api from : https://www.pinecone.io/
PINECONE_API_KEY

PINECONE_INDEX
PINECONE_CLOUD
PINECONE_REGION

# HuggingFace API Token
# Get your API token from: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN
GROQ_API_KEY
COHERE_API_KEY